{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "defaultValue": "CentralIndia",
            "type": "String"
        },
        "adminUsername": {
            "defaultValue": "azuser",
            "type": "String"
        },
        "adminPassword": {
            "type": "SecureString"
        },
        "name": {
            "defaultValue": "ipconfig1",
            "type": "String",
            "metadata": {
                "description": "The name of the resource that is unique within a resource group. This name can be used to access the resource."
            }
        }
    },
    "resources": [
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2023-05-01",
            "name": "webvmnet_01",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "172.18.10.0/24"
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks/subnets",
            "apiVersion": "2023-05-01",
            "name": "webvmnet_01/websubnet01",
            "dependsOn": [
                "webvmnet_01"
            ],
            "properties": {
                "addressPrefix": "172.18.10.0/25"
            }
        },
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "apiVersion": "2023-05-01",
            "name": "webvm01-nsg",
            "location": "[parameters('location')]",
            "properties": {
                "securityRules": [
                    {
                        "name": "AllowHttp",
                        "properties": {
                            "priority": 1001,
                            "protocol": "Tcp",
                            "access": "Allow",
                            "direction": "Inbound",
                            "sourceAddressPrefix": "*",
                            "sourcePortRange": "*",
                            "destinationAddressPrefix": "*",
                            "destinationPortRange": "80"
                        }
                    },
                    {
                        "name": "AllowSSH",
                        "properties": {
                            "priority": 1002,
                            "protocol": "Tcp",
                            "access": "Allow",
                            "direction": "Inbound",
                            "sourceAddressPrefix": "*",
                            "sourcePortRange": "*",
                            "destinationAddressPrefix": "*",
                            "destinationPortRange": "22"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2023-05-01",
            "name": "webvm01-ip",
            "location": "[parameters('location')]",
            "sku": {
                "name": "Standard"
            },
            "properties": {
                "publicIPAllocationMethod": "Static"
            }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2023-05-01",
            "name": "webvm01-nic",
            "location": "[parameters('location')]",
            "dependsOn": [
                "webvmnet_01",
                "websubnet01",
                "webvm01-nsg",
                "webvm01-ip"
            ],
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "[parameters('name')]",
                        "properties": {
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets','webvmnet_01','websubnet01')]"
                            },
                            "privateIPAllocationMethod": "Dynamic",
                            "publicIPAddress": {
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses','webvm01-ip')]"
                            }
                        }
                    }
                ],
                "networkSecurityGroup": {
                    "id": "[resourceId('Microsoft.Network/networkSecurityGroups','webvm01-nsg')]"
                }
            }
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2023-09-01",
            "name": "webvm01",
            "location": "[parameters('location')]",
            "dependsOn": [
                "webvm01-nic"
            ],
            "properties": {
                "hardwareProfile": {
                    "vmSize": "Standard_B2ats_v2"
                },
                "osProfile": {
                    "computerName": "webvm01",
                    "adminUsername": "[parameters('adminUsername')]",
                    "adminPassword": "[parameters('adminPassword')]"
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "Canonical",
                        "offer": "0001-com-ubuntu-server-jammy",
                        "sku": "22_04-lts-gen2",
                        "version": "latest"
                    },
                    "osDisk": {
                        "createOption": "FromImage"
                    },
                    "dataDisks": [
                        {
                            "lun": 0,
                            "name": "webvm01_data_disk01",
                            "createOption": "Empty",
                            "diskSizeGB": 128
                        },
                        {
                            "lun": 1,
                            "name": "containers_data_web_app",
                            "createOption": "Empty",
                            "diskSizeGB": 128
                        }
                    ]
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[resourceId('Microsoft.Network/networkInterfaces','webvm01-nic')]"
                        }
                    ]
                }
            }
        }
    ]
}