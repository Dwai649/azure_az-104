{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {},
    "functions": [],
    "variables": {

        "location": "[resourceGroup().location]",
        "nsgName": "nsg-dev-01",
        "rulesshName": "allow-ssh-admin",
        "rulesshPriority": 400,
        "sshPort": "22",
        "svcTagInternet": "Internet",
        "httpDestIp": "10.0.0.4",
        "httpPort": "80",
        "ruleHttpName": "in-allow-http-from-internet-to-10-0-0-4",
        "ruleHttpPriority": 410


    },
    "resources": [

             {
            "name": "[variables('nsgName')]",
            "type": "Microsoft.Network/networkSecurityGroups",
            "apiVersion": "2024-07-01",
            "location": "[variables('location')]",

            "properties": {
                "securityRules": [
                    {
                        "name": "[variables('rulesshName')]",
                        "properties": {
                            "description": "[variables('rulesshName')]",
                            "protocol": "Tcp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "[variables('sshPort')]",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": "[variables('rulesshPriority')]",
                            "direction": "Inbound"
                        }
                    },
                    {
                        "name": "[variables('ruleHttpName')]",
                        "properties": {
                            "description": "[variables('ruleHttpName')]",
                            "protocol": "Tcp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "[variables('httpPort')]",
                            "sourceAddressPrefix": "[variables('svcTagInternet')]",
                            "destinationAddressPrefix": "[variables('httpDestIp')]",
                            "access": "Allow",
                            "priority": "[variables('ruleHttpPriority')]",
                            "direction": "Inbound"
                        }
                    }
                ]
            }
        },

          {
            "name": "vnet-dev-eus-01",
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2024-07-01",
            "location": "centralindia",
             "dependsOn": [
                     "[resourceId('Microsoft.Network/networkSecurityGroups', 'nsg-dev-01')]"],
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.0.0.0/16"
                    ]
                },
                "subnets": [
                    {
                        "name": "[concat('vnet-dev-eus-01','-','subnet01')]" ,
                        "properties": {
                            "addressPrefix": "10.0.1.0/24",
                            "networkSecurityGroup": {

                                "id": "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-dev-01')]"

                            }
                            
                        }
                    },
                    {
                        "name": "[concat('vnet-dev-eus-01','-','subnet02')]" ,
                        "properties": {
                            "addressPrefix": "10.0.2.0/24",
                              "networkSecurityGroup": {

                                "id": "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-dev-01')]"
                                
                            }
                         
                        }
                    }
                ]
            }
        },
        {
            "name": "pip-web-dev-eus-01",
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2024-07-01",
            "location": "[resourceGroup().location]",
            "sku":{
                "name":"Standard"
            },
            "properties": {
                "publicIPAllocationMethod": "Static"
            }
        },
         {
            "name": "[concat('nic-web-', resourceGroup().name)]",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2024-07-01",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                     "[resourceId('Microsoft.Network/virtualNetworks', 'vnet-dev-eus-01')]",
                      "[resourceId('Microsoft.Network/publicIPAddresses','pip-web-dev-eus-01')]"
                        ],
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig-web-01",
                        "properties": {
                            "privateIPAllocationMethod": "Dynamic",
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'vnet-dev-eus-01', 'vnet-dev-eus-01-subnet01')]"
                            },
                            "publicIPAddress":{
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses','pip-web-dev-eus-01')]"
                            }
                        }
                    }
                ]
            }
        }

        

     

    ],
     
    
    "outputs": {}
}